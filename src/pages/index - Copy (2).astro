---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<nav class="navbar">
  <div class="logo">AWS SysOps Portfolio</div>

  <div class="nav-links">
    <a href="#summary">Summary</a>
    <a href="#skills">Skills</a>
    <a href="#projects">Projects</a>
    <a href="#experience">Experience</a>
    <a href="#contact">Contact</a>

    <a class="btn" href="/cv.pdf" target="_blank">Download CV</a>
  </div>
</nav>

<main class="container">

  <!-- HERO -->
  <section class="hero">

    <!-- PROFILE IMAGE -->
    <img src="/profile.jpg" alt="Luvuyo Mnguni" class="profile-img" />

    <h1>Luvuyo Collen Mnguni</h1>
    <h2>AWS SysOps Engineer | Cloud Operations Specialist</h2>

    <p>
      13+ years in IT Operations, Cloud Infrastructure, Application Support,
      and Enterprise Systems Management with strong AWS automation experience.
    </p>

    <p class="contact">
      📍 Roodepoort, Gauteng |
      📧 <a href="mailto:mnguni.luvuyo@gmail.com">mnguni.luvuyo@gmail.com</a> |
      📞 068 289 8792
    </p>

  </section>

  <!-- SUMMARY -->
  <section id="summary" class="card">
    <h3>Professional Summary</h3>

    <p>
      Results-driven IT Operations and Cloud Infrastructure Specialist with 13+ years of experience
      across AWS cloud operations, enterprise systems administration, application support, and IT service management.
      Proven ability to design automation solutions delivering measurable cost savings including a 99.8% reduction in AWS RDS runtime.
    </p>

    <p>
      Strong expertise in Incident, Problem, and Change Management with ITIL-aligned service delivery.
      Hands-on experience with AWS EC2, RDS, S3, IAM, Lambda, CloudWatch, and EventBridge.
    </p>
  </section>

  <!-- SKILLS -->
  <section id="skills" class="card">
    <h3>☁️ AWS & Cloud Skills</h3>

    <div class="grid">
      <span>EC2</span><span>RDS</span><span>S3</span><span>IAM</span>
      <span>Lambda</span><span>EventBridge</span><span>CloudWatch</span>
      <span>Auto Scaling</span><span>Cost Optimization</span>
    </div>

    <h3 style="margin-top:20px;">ITSM & Operations</h3>

    <div class="grid">
      <span>ITIL</span><span>Incident Management</span><span>Problem Management</span>
      <span>Change Management</span><span>SLA Management</span><span>RCA</span>
      <span>Production Support</span>
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects" class="card">
    <h3>🚀 Key Projects</h3>

    <div class="project">
      <h4>AWS RDS Automation & Cost Optimization</h4>
      <p>
        Automated non-production RDS scheduling using AWS Lambda and EventBridge.
        Achieved 99.8% runtime reduction (744h → 1.33h/month).
      </p>
    </div>

    <div class="project">
      <h4>EC2 Auto Scaling Scheduling</h4>
      <p>
        Implemented scheduled start/stop automation for Auto Scaling Groups to reduce AWS costs in non-production environments.
      </p>
    </div>

    <div class="project">
      <h4>CloudWatch Monitoring Strategy</h4>
      <p>
        Built proactive monitoring and alerting framework for early incident detection and improved system visibility.
      </p>
    </div>

    <div class="project">
      <h4>Self-Service ITSM Portal</h4>
      <p>
        Developed Remedy ITSM integration portal to automate ticket creation and improve global support efficiency.
      </p>
    </div>

    <div class="project">
      <h4>Tenant Statement Automation</h4>
      <p>
        Automated tenant statement email distribution using data validation and SMTP integration.
      </p>
    </div>

  </section>

  <!-- EXPERIENCE -->
  <section id="experience" class="card">
    <h3>💼 Experience</h3>

    <div class="job">
      <h4>AWS SysOps Engineer – Valenture Institute</h4>
      <p>Cloud operations, AWS automation, monitoring, incident response, and cost optimization.</p>
    </div>

    <div class="job">
      <h4>System Administrator – TransUnion</h4>
      <p>Enterprise support across AWS EC2, Salesforce, Amazon Connect, and global ITSM systems.</p>
    </div>

    <div class="job">
      <h4>IT Business Analyst – Excellerate</h4>
      <p>Systems support, SQL reporting, UAT testing, vendor coordination, and process improvement.</p>
    </div>

  </section>

  <!-- EDUCATION -->
  <section class="card">
    <h3>🎓 Education</h3>
    <p>BSc Honours in Computing (UNISA, 2027)</p>
    <p>Advanced Diploma in Information Resource Management (2021)</p>
    <p>National Diploma – Computer Systems Engineering (UJ, 2014)</p>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="card">
    <h3>📫 Contact</h3>

    <p>GitHub: <a href="https://github.com/vmnguni" target="_blank">github.com/vmnguni</a></p>
    <p>LinkedIn: <a href="https://linkedin.com/in/luvuyo-mnguni-80414438" target="_blank">linkedin.com/in/luvuyo-mnguni</a></p>
    <p>Email: <a href="mailto:mnguni.luvuyo@gmail.com">mnguni.luvuyo@gmail.com</a></p>

  </section>

</main>

</Layout>

<style>

body {
  font-family: system-ui, Arial, sans-serif;
  background: linear-gradient(135deg, #0b1220 0%, #111827 50%, #0f172a 100%);
  color: #e5e7eb;
  line-height: 1.6;
}

/* NAVBAR */
.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 25px;
  position: sticky;
  top: 0;
  background: rgba(11,18,32,0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(148,163,184,0.1);
}

.logo {
  font-weight: bold;
  color: #fff;
}

.nav-links {
  display: flex;
  gap: 14px;
  align-items: center;
}

.nav-links a {
  color: #cbd5e1;
  font-size: 14px;
}

.btn {
  background: #3b82f6;
  padding: 6px 12px;
  border-radius: 8px;
  color: white !important;
}

/* CONTAINER */
.container {
  max-width: 1000px;
  margin: auto;
  padding: 40px 20px;
}

/* HERO */
.hero {
  text-align: center;
  padding: 60px 20px;
}

.profile-img {
  width: 140px;
  height: 140px;
  border-radius: 50%;
  object-fit: cover;
  border: 4px solid #3b82f6;
  margin-bottom: 15px;
  box-shadow: 0 0 20px rgba(59,130,246,0.4);
}

.hero h1 {
  font-size: 42px;
  color: #fff;
}

.hero h2 {
  color: #60a5fa;
}

.hero p {
  color: #cbd5e1;
  max-width: 750px;
  margin: auto;
}

.contact {
  margin-top: 12px;
  color: #94a3b8;
}

/* CARD */
.card {
  background: rgba(17, 24, 39, 0.85);
  padding: 22px;
  margin: 20px 0;
  border-radius: 14px;
  border: 1px solid rgba(148,163,184,0.1);
}

/* SKILLS */
.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.grid span {
  background: #1f2937;
  padding: 7px 12px;
  border-radius: 8px;
  font-size: 13px;
}

/* PROJECTS */
.project, .job {
  margin-top: 15px;
  padding-left: 12px;
  border-left: 3px solid #3b82f6;
}

/* LINKS */
a {
  color: #60a5fa;
  text-decoration: none;
}

a:hover {
  color: #93c5fd;
  text-decoration: underline;
}

</style>