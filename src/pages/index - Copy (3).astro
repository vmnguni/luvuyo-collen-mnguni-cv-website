<style>

body {
  font-family: system-ui, Arial, sans-serif;
  background: linear-gradient(135deg, #0b1220, #111827, #0f172a);
  color: #e5e7eb;
  line-height: 1.6;
}

.navbar {
  display:flex;
  justify-content:space-between;
  padding:15px 25px;
  position:sticky;
  top:0;
  background:rgba(10,15,25,0.9);
  backdrop-filter:blur(10px);
}

.nav-links a {
  margin:0 8px;
  color:#cbd5e1;
  text-decoration:none;
}

.btn {
  background:#3b82f6;
  padding:6px 12px;
  border-radius:8px;
  color:white !important;
}

.container {
  max-width:1100px;
  margin:auto;
  padding:40px 20px;
}

.hero {
  text-align:center;
  padding:60px 20px;
}

.profile-img {
  width:140px;
  height:140px;
  border-radius:50%;
  border:4px solid #3b82f6;
  margin-bottom:15px;
}

.card {
  background:rgba(17,24,39,0.85);
  padding:22px;
  margin:20px 0;
  border-radius:14px;
}

.grid {
  display:flex;
  flex-wrap:wrap;
  gap:10px;
}

.grid span {
  background:#1f2937;
  padding:6px 10px;
  border-radius:8px;
  font-size:13px;
}

.job {
  border-left:3px solid #3b82f6;
  padding-left:12px;
  margin-top:15px;
}

a { color:#60a5fa; }

</style>